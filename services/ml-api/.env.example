# Shared bearer secret. The Firebase Cloud Function (forecastNutrition) must be
# configured with the SAME value so it can authenticate to this service.
# Generate one with:  openssl rand -hex 32
ML_API_SECRET=replace-with-a-long-random-string

# --- Firebase service-account credentials (READ access to Firestore) ---
# Provide ONE of the two options below. If both are set, the JSON string wins.
#
# Option A (LOCAL DEV): path to the service-account JSON key file.
FIREBASE_SERVICE_ACCOUNT_JSON_PATH=./serviceAccount.json
#
# Option B (CLOUD DEPLOY, e.g. Railway): the FULL contents of the key file as a
# single-line JSON string. Railway can't easily ship a file, so paste the whole
# JSON here instead. Takes priority over the path above when set and non-empty.
# Example (dummy values, must be a single line):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"macro-map-afa5e","private_key_id":"abc123","private_key":"-----BEGIN PRIVATE KEY-----\nMIIxxx...\n-----END PRIVATE KEY-----\n","client_email":"sa@macro-map-afa5e.iam.gserviceaccount.com","client_id":"123456789","token_uri":"https://oauth2.googleapis.com/token"}
